# docker-compose bu değişkenleri kullanır
RADARR_API_KEY=radarr_api_anahtariniz

# --- opsiyonel ---
# film eklenince ntfy bildirimi (ntfy.sh topic adı)
YTA_NTFY_TOPIC=
# eşleşen filmleri her döngüde otomatik indir
YTA_AUTO_DOWNLOAD=false
# yeni yükleme takibi için resmi YouTube kanalları (@handle veya URL, virgülle)
YTA_CHANNEL_FEEDS=
# TMDB import listesi (Radarr'dan bağımsız) — API anahtarı + aç
YTA_TMDB_API_KEY=
YTA_TMDB_LIST_ENABLED=false
